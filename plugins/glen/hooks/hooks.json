{
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "glen session-start --agent claude-code" }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "glen ingest --agent claude-code" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "glen ingest --agent claude-code" }] }
    ],
    "PostToolUse": [
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": "glen pr-link --agent claude-code" }] }
    ]
  }
}
